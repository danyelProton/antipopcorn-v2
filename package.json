{
  "name": "antipopcorn-v2",
  "type": "module",
  "scripts": {
    "bundle:sync": "esbuild backend/sync/index.js --bundle --platform=node --target=node22 --format=cjs --outfile=dist/sync/sync.js --external:jsdom --external:puppeteer-core --external:puppeteer-extra --external:puppeteer-extra-plugin-stealth --external:@sparticuz/chromium-min",
    "bundle:api": "esbuild backend/api/index.js --bundle --platform=node --outfile=api/index.js",
    "vercel-build": "npm run bundle:api"
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  },
  "workspaces": [
    "backend/api",
    "backend/sync",
    "backend/shared",
    "frontend"
  ],
  "dependencies": {
    "jsdom": "^22.1.0"
  }
}